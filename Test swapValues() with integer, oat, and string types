#include<iostream>
using namespace std;
class SWAP{
    public:
    int i;float j;string k;
    void swap(int a,int b){
        i=a;
        a=b;
        b=i;
        cout<<"after swap"<<endl<<"a="<<a<<endl<<"b="<<b<<endl;
    
    }
    void swap(float c,float d){
        j=c;
        c=d;
        d=j;
        cout<<"after swap"<<endl<<"c="<<c<<endl<<"d="<<d<<endl;
    }
    void swap(string s1,string s2){
        k=s1;
        s1=s2;
        s2=k;
        cout<<"after swap"<<endl<<"s1="<<s1<<endl<<"s2="<<s2<<endl;
    }
};
int main(){
    SWAP s;string s1="ram",s2="sree";
    s.swap(15,15);
    s.swap(12.5f,4.5f);
    s.swap(s1,s2);
}
//output
after swap
a=15
b=15
after swap
c=4.5
d=12.5
after swap
s1=sree
s2=ram


